@page
@model Module2_FacultyPages.Pages.Index1Model
@{
    ViewData["Title"] = "Contact Profile";
}
<h2>Course Interest Form</h2>
<p>Complete the form below to receive more information about upcoming technology courses.</p>

<form style="background: #f9f9f9; padding: 20px; border-radius: 8px; border: 1px solid #ddd;">
    <div style="margin-bottom: 15px;">
        <label for="name" style="display: block; font-weight: bold;">Full Name:</label>
        <input type="text" id="name" name="name" placeholder="John Doe" style="width: 100%; padding: 8px;">
    </div>

    <div style="margin-bottom: 15px;">
        <label for="email" style="display: block; font-weight: bold;">Student Email:</label>
        <input type="email" id="email" name="email" placeholder="doe.john@live.spcollege.edu" style="width: 100%; padding: 8px;">
    </div>

    <div style="margin-bottom: 15px;">
        <label for="course" style="display: block; font-weight: bold;">Course of Interest:</label>
        <select id="course" name="course" style="width: 100%; padding: 8px;">
            <option value="">-- Select a Course --</option>
            <option value="dotnet">.NET Development</option>
            <option value="pm">Project Management</option>
            <option value="uiux">UI/UX Design</option>
        </select>
    </div>

    <div style="margin-bottom: 15px;">
        <label style="display: block; font-weight: bold;">Message/Questions:</label>
        <textarea rows="4" style="width: 100%; padding: 8px;"></textarea>
    </div>

    <button type="button" style="background: #003a70; color: white; padding: 10px 20px; border: none; cursor: pointer;">
        Submit Interest
    </button>
</form>